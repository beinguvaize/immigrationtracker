# Required environment variables for local development and Vercel deployment.
# Copy this file to .env and fill in your values.
# DO NOT commit .env to Git.

# Turso Database connection (from https://turso.tech/app)
DATABASE_URL=libsql://YOUR_DB_NAME.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# JWT Secret — generate a strong random string for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_here
